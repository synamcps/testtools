# URL of the MCP HTTP endpoint. Examples:
#   Streamable HTTP (default FastMCP path): http://localhost:8000/mcp
#   Legacy SSE (FastMCP default):            http://localhost:8001/sse
MCP_SERVER_URL=http://localhost:8000/mcp

# Transport: http | streamable-http | streamable | sse
#   "http" selects the streamable HTTP client transport (recommended for remote MCP).
MCP_TRANSPORT=http

# Optional JSON object of extra HTTP headers (strings only), e.g. bearer tokens.
# MCP_HTTP_HEADERS={"Authorization":"Bearer YOUR_TOKEN"}

# For streamable HTTP, send DELETE on shutdown to end the server session (default: true).
# MCP_HTTP_TERMINATE_ON_CLOSE=true

# Optional: DEBUG, INFO, WARNING, ERROR
# MCP_CLIENT_LOG_LEVEL=WARNING
